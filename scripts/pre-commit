#!/bin/bash

# Pre-commit hook for ekoDB Client Libraries
# Runs full checks via make targets

set -e

CYAN='\033[36m'
GREEN='\033[32m'
RED='\033[31m'
RESET='\033[0m'

echo -e "${CYAN}🔍 Running pre-commit checks...${RESET}"

make examples-ls-check || { echo -e "${RED}❌ examples-ls-check failed (run 'make examples-ls' to update)${RESET}"; exit 1; }
make fmt || { echo -e "${RED}❌ fmt failed${RESET}"; exit 1; }
make lint 2>/dev/null || true
make build || { echo -e "${RED}❌ build failed${RESET}"; exit 1; }
make test || { echo -e "${RED}❌ tests failed${RESET}"; exit 1; }

echo -e "${GREEN}✅ All pre-commit checks passed!${RESET}"
exit 0
